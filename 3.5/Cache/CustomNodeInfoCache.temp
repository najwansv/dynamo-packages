  "C:\\Users\\najwa\\AppData\\Roaming\\Dynamo\\Dynamo Revit\\3.6\\packages\\Ampersand\\dyf\\[\u0026] Vector.ByAltitudeAzimuth.dyf5/19/2019 1:43:10 PM21160": {
    "FunctionId": "930e3d85-439f-41ca-86eb-a34eafe0d8e1",
    "Name": "[\u0026] Vector.ByAltitudeAzimuth",
    "Category": "Ampersand",
    "Description": "Create a unit vector by its altitude and azimuth.  The positive Y axis is taken as north and the positive Z axis is taken as up.\r\n\r\nAltitudinal convention is:\r\n90\u00B0 = straight up (\u002BZ axis),\r\n0\u00B0 = horizontal,\r\n-90\u00B0 = straight down (-Z axis).\r\n\r\nAzimuthal convention is:\r\n0\u00B0 = North (\u002BY axis),\r\n90\u00B0 = East (\u002BX axis),\r\n180\u00B0 = South (-Y axis),\r\n270\u00B0 = West (-X axis).",
    "Path": "C:\\Users\\najwa\\AppData\\Roaming\\Dynamo\\Dynamo Revit\\3.6\\packages\\Ampersand\\dyf\\[\u0026] Vector.ByAltitudeAzimuth.dyf",
    "IsPackageMember": true,
    "IsVisibleInDynamoLibrary": true,
    "PackageInfo": {
      "Name": "Ampersand",
      "Version": "2022.1.25"
    }
  },
